
<div class="col-sm-4 offset-sm-4 mt-5">
  <h1><%= @article.title %></h1>
  <p><%= @article.content %></p>
  <p>
    <%= link_to "Edit article", edit_article_path, class: "btn btn-outline-success text-decoration-none mr-2" %>
    <%=
      link_to "Delete article",
      article_path(@article),
      data: {turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this article?"},
      class: "btn btn-warning"
    %>
   </p>
</div>
